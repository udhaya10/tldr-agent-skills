        {
          "change_type": "update",
          "node_kind": "expression",
          "name": "\"\"\"         Fetch historical daily OHLCV data from Yahoo Finance.          Match...",
          "old_location": {
            "file": "backend/providers/yahoo.py",
            "line": 44,
            "column": 8,
            "end_line": 50,
