    {
      "change_type": "update",
      "node_kind": "method",
      "name": "fetch_historical_data",
      "old_location": {
        "file": "backend/providers/yahoo.py",
        "line": 38,
        "column": 4
      },
      "new_location": {
        "file": "backend/providers/dhan.py",
        "line": 49,
        "column": 4
      },
      "old_text": "def fetch_historical_data(\n        self,\n        symbol: str,\n        start_date: date,\n        end_date: date,\n    ) -> pd.DataFrame:\n        \"\"\"\n        Fetch historical daily OHLCV data from Yahoo Finance.\n\n        Matches existing behavior from market_data.py:\n        - Uses auto_adjust=False (unadjusted prices)\n        - Returns UTC-normalized timestamps\n        \"\"\"\n        try:\n            df = yf.download(\n                symbol,\n                start=start_date,\n                end=end_date,\n                auto_adjust=False,\n                progress=False,\n            )\n\n            if df.empty:\n                return pd.DataFrame()\n\n            # Normalize to UTC and ensure required columns\n            if df.index.name == \"Date\":\n                df.index = pd.to_datetime(df.index, utc=True)\n            else:\n                df.index = pd.to_datetime(df.index)\n                if df.index.tzinfo is None:\n                    df.index = df.index.tz_localize(\"UTC\")\n\n            df.index.name = \"time\"\n\n            # Rename columns to lowercase\n            df.columns = [col.lower() for col in df.columns]\n\n            # Keep only OHLCV\n            required = [\"open\", \"high\", \"low\", \"close\", \"volume\"]\n            available = [col for col in required if col in df.columns]\n            df = df[available]\n\n            return df\n\n        except Exception as error:\n            print(f\"Error fetching historical data for {symbol}: {error}\")\n            return pd.DataFrame()",
      "new_text": "def fetch_historical_data(\n        self,\n        symbol: str,\n        start_date: date,\n        end_date: date,\n    ) -> pd.DataFrame:\n        \"\"\"\n        Fetch historical daily OHLCV from Dhan.\n\n        Args:\n            symbol: Yahoo-format symbol (e.g. 'RELIANCE.NS')\n            start_date: Inclusive start date\n            end_date: Inclusive end date (Dhan is inclusive on both ends)\n\n        Returns:\n            DataFrame with UTC DatetimeIndex named 'time' and columns\n            [open, high, low, close, volume]. Empty DataFrame on any failure.\n\n        Note:\n            Dhan timestamps are Unix seconds at 18:30 UTC (midnight IST).\n            Stored as-is; timestamp alignment with Yahoo is a Phase 3 concern.\n        \"\"\"\n        mappings = self._load_mappings()\n        info = mappings.get(symbol)\n        if info is None:\n            return pd.DataFrame()\n\n        security_id, exchange_segment, instrument_type = info\n        start_str = start_date.strftime(\"%Y-%m-%d\")\n        end_str = end_date.strftime(\"%Y-%m-%d\")\n\n        try:\n            dhan = self._get_client()\n            response = dhan.historical_daily_data(\n                str(security_id),\n                exchange_segment,\n                instrument_type,\n                start_str,\n                end_str,\n            )\n        except Exception as error:\n            from backend.dhan_client import DhanAuthError\n            if isinstance(error, DhanAuthError):\n                raise\n            print(f\"[DhanProvider] API error for {symbol}: {error}\")\n            return pd.DataFrame()\n\n        if response.get(\"status\") != \"success\":\n            print(f\"[DhanProvider] Non-success response for {symbol}: {response.get('status')}\")\n            return pd.DataFrame()\n\n        data = response.get(\"data\", {})\n        timestamps = data.get(\"timestamp\", [])\n        opens = data.get(\"open\", [])\n        highs = data.get(\"high\", [])\n        lows = data.get(\"low\", [])\n        closes = data.get(\"close\", [])\n        volumes = data.get(\"volume\", [])\n\n        if not timestamps or not closes:\n            return pd.DataFrame()\n\n        index = pd.to_datetime(timestamps, unit=\"s\", utc=True)\n        df = pd.DataFrame(\n            {\n                \"open\": opens,\n                \"high\": highs,\n                \"low\": lows,\n                \"close\": closes,\n                \"volume\": volumes,\n            },\n            index=index,\n        )\n        df.index.name = \"time\"\n        df = df.dropna(subset=[\"close\"])\n        return df",
      "similarity": 0.14457831325301204,
