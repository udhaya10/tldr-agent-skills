      "old_text": "def fetch_market_cap(self, symbol: str) -> Optional[float]:\n        \"\"\"\n        Fetch market cap from Yahoo Finance.\n\n        Matches existing logic from market_data.py.\n        \"\"\"\n        try:\n            ticker_obj = yf.Ticker(symbol)\n            fast_info = ticker_obj.fast_info\n\n            # Try direct market cap\n            market_cap = _to_finite_float(fast_info.get(\"marketCap\"))\n            if market_cap is not None:\n                return market_cap\n\n            # Try shares × price\n            shares = _to_finite_float(fast_info.get(\"shares\"))\n            last_price = _to_finite_float(fast_info.get(\"lastPrice\"))\n            if shares is not None and last_price is not None:\n                return shares * last_price\n\n            # Try info dict\n            info = ticker_obj.info or {}\n            return _to_finite_float(info.get(\"marketCap\") or info.get(\"currentMarketCap\"))\n\n        except Exception:\n            return None",
      "new_text": "def fetch_market_cap(self, symbol: str) -> Optional[float]:\n        \"\"\"Dhan does not provide market cap via historical API.\"\"\"\n        return None",
      "similarity": 0.05555555555555555
    },
