      "old_text": "def fetch_intraday_chart(\n        self,\n        symbol: str,\n        interval: str,\n        period_bars: int,\n    ) -> pd.DataFrame:\n        \"\"\"\n        Fetch intraday chart data from Yahoo Finance.\n\n        Matches existing behavior from api.py:\n        - Uses auto_adjust=True (adjusted prices for charts)\n        - Returns most recent N bars\n        \"\"\"\n        try:\n            # Convert period_bars to yfinance period format\n            # period_bars=100 → roughly 1m candles = 100 minutes = ~4 hours\n            # Use a safe estimate: period_bars * interval seconds / market hours\n            period = \"1d\"  # Start with 1 day, yfinance will truncate to latest N bars\n            if interval in [\"1m\", \"5m\"]:\n                period = \"7d\"\n            elif interval in [\"15m\", \"30m\"]:\n                period = \"30d\"\n            elif interval in [\"1h\"]:\n                period = \"60d\"\n\n            df = yf.download(\n                symbol,\n                period=period,\n                interval=interval,\n                auto_adjust=True,\n                progress=False,\n            )\n\n            if df.empty:\n                return pd.DataFrame()\n\n            # Normalize to UTC\n            if df.index.tzinfo is None:\n                df.index = df.index.tz_localize(\"UTC\")\n            else:\n                df.index = df.index.tz_convert(\"UTC\")\n\n            df.index.name = \"time\"\n\n            # Keep only latest N bars\n            if len(df) > period_bars:\n                df = df.tail(period_bars)\n\n            # Rename columns to lowercase\n            df.columns = [col.lower() for col in df.columns]\n\n            # Keep only OHLCV\n            required = [\"open\", \"high\", \"low\", \"close\", \"volume\"]\n            available = [col for col in required if col in df.columns]\n            df = df[available]\n\n            return df\n\n        except Exception as error:\n            print(f\"Error fetching intraday chart for {symbol}: {error}\")\n            return pd.DataFrame()",
      "new_text": "def fetch_intraday_chart(\n        self,\n        symbol: str,\n        interval: str,\n        period_bars: int,\n    ) -> pd.DataFrame:\n        \"\"\"\n        Fetch intraday OHLCV from Dhan's /charts/intraday endpoint.\n\n        Args:\n            symbol: Yahoo-format symbol (e.g. 'RELIANCE.NS')\n            interval: yfinance-style interval string ('1m', '5m', '15m', '25m', '60m', '1h')\n            period_bars: If > 0, trim result to the last N bars. 0 = return all.\n\n        Returns:\n            DataFrame with UTC DatetimeIndex named 'time' and columns\n            [open, high, low, close, volume]. Empty on any failure.\n            Dhan supports last 5 trading days of intraday data.\n        \"\"\"\n        _interval_map = {\"1m\": 1, \"5m\": 5, \"15m\": 15, \"25m\": 25, \"60m\": 60, \"1h\": 60}\n        dhan_interval = _interval_map.get(interval)\n        if dhan_interval is None:\n            return pd.DataFrame()\n\n        mappings = self._load_mappings()\n        info = mappings.get(symbol)\n        if info is None:\n            return pd.DataFrame()\n\n        security_id, exchange_segment, instrument_type = info\n\n        from datetime import date, timedelta\n        end_date = date.today()\n        start_date = end_date - timedelta(days=7)  # covers ~5 trading days\n        start_str = start_date.strftime(\"%Y-%m-%d\")\n        end_str = end_date.strftime(\"%Y-%m-%d\")\n\n        try:\n            dhan = self._get_client()\n            response = dhan.intraday_minute_data(\n                str(security_id),\n                exchange_segment,\n                instrument_type,\n                start_str,\n                end_str,\n                interval=dhan_interval,\n            )\n        except Exception as error:\n            from backend.dhan_client import DhanAuthError\n            if isinstance(error, DhanAuthError):\n                raise\n            print(f\"[DhanProvider] Intraday API error for {symbol}: {error}\")\n            return pd.DataFrame()\n\n        if response.get(\"status\") != \"success\":\n            return pd.DataFrame()\n\n        data = response.get(\"data\", {})\n        timestamps = data.get(\"timestamp\", [])\n        opens = data.get(\"open\", [])\n        highs = data.get(\"high\", [])\n        lows = data.get(\"low\", [])\n        closes = data.get(\"close\", [])\n        volumes = data.get(\"volume\", [])\n\n        if not timestamps or not closes:\n            return pd.DataFrame()\n\n        index = pd.to_datetime(timestamps, unit=\"s\", utc=True)\n        df = pd.DataFrame(\n            {\"open\": opens, \"high\": highs, \"low\": lows, \"close\": closes, \"volume\": volumes},\n            index=index,\n        )\n        df.index.name = \"time\"\n        df = df.dropna(subset=[\"close\"])\n\n        if period_bars > 0 and len(df) > period_bars:\n            df = df.iloc[-period_bars:]\n\n        return df",
      "similarity": 0.13333333333333333
    },
