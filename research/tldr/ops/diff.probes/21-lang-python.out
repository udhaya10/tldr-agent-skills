      "old_text": "def fetch_metadata(self, symbol: str) -> Dict[str, Any]:\n        \"\"\"\n        Fetch metadata for a symbol.\n        \"\"\"\n        try:\n            ticker_obj = yf.Ticker(symbol)\n            fast_info = ticker_obj.fast_info or {}\n            info = ticker_obj.info or {}\n\n            return {\n                \"market_cap\": _to_finite_float(\n                    fast_info.get(\"marketCap\") or info.get(\"marketCap\")\n                ),\n                \"shares_outstanding\": _to_finite_float(fast_info.get(\"shares\")),\n                \"currency\": fast_info.get(\"currency\") or info.get(\"currency\"),\n                \"sector\": info.get(\"sector\"),\n                \"industry\": info.get(\"industry\"),\n            }\n\n        except Exception as error:\n            print(f\"Error fetching metadata for {symbol}: {error}\")\n            return {}",
      "new_text": "def fetch_metadata(self, symbol: str) -> Dict[str, Any]:\n        \"\"\"Return mapping metadata from dhan_symbol_map.\"\"\"\n        mappings = self._load_mappings()\n        info = mappings.get(symbol)\n        if info is None:\n            return {}\n        security_id, exchange_segment, instrument_type = info\n        return {\n            \"security_id\": security_id,\n            \"exchange_segment\": exchange_segment,\n            \"instrument_type\": instrument_type,\n        }",
