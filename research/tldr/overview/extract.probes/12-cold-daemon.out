    {
      "name": "ensure_provider_ohlcv_table",
      "params": [
        "conn"
      ],
      "docstring": "\n    Create provider_ohlcv table if it doesn't exist.\n\n    This is a shadow table for parallel provider data ingestion.\n    Allows Dhan and other providers to write data independently\n    without affecting the canonical stock_data table.\n\n    Schema:\n    - provider: Data source name ('yahoo', 'dhan', etc.)\n    - symbol: Stock ticker\n    - interval: Candle interval ('daily', '1m', '5m', '15m', etc.)\n    - time: ISO 8601 UTC timestamp\n    - OHLCV: Open, High, Low, Close, Volume\n    - marketcap: Optional market cap snapshot\n    - fetched_at: When this data was fetched\n    ",
      "is_method": false,
      "is_async": false,
      "line": 56,
      "line_end": 101
    },
