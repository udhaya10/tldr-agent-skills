    "function_name": "fetch_historical_data",
    "class_name": "HistoricalDataProvider",
    "line_start": 19,
    "line_end": 43,
    "content": "def fetch_historical_data(\n        self,\n        symbol: str,\n        start_date: date,\n        end_date: date,\n    ) -> pd.DataFrame:\n        \"\"\"\n        Fetch historical daily OHLCV data.\n\n        Args:\n            symbol: Ticker/security identifier (e.g., 'RELIANCE')\n            start_date: Inclusive start date\n            end_date: Inclusive end date\n\n        Returns:\n            DataFrame with columns: [time, open, high, low, close, volume]\n            - time: ISO 8601 UTC timestamps (index)\n            - open, high, low, close: OHLC prices (float)\n            - volume: Trading volume (int)\n\n        Raises:\n            ValueError: If symbol not found or invalid date range\n            Exception: On network/API errors\n        \"\"\"\n        pass",
    "content_hash": "c5debe5427a47567f14acae244015d91",
    "language": "python"
  },
